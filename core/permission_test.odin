	// chain: any write segment → not readonly
	d = check_tool(.Ask, "run_terminal_cmd", "ls && rm -rf /tmp/x", nil, nil)
	testing.expect(t, d == .Ask, "mixed chain still asks")
	// opt-out soft
	os.set_env("AETHER_NO_BASH_SOFT", "1")
	defer os.unset_env("AETHER_NO_BASH_SOFT")
	d = check_tool(.Always_Approve, "run_terminal_cmd", "rm -rf /", nil, nil)
	testing.expect(t, d == .Allow, "soft off allows under yolo")
}

@(test)
test_auto_mode_accepts_edits_asks_bash :: proc(t: ^testing.T) {
	d := check_tool(.Auto, "search_replace", "", nil, nil)
	testing.expect(t, d == .Allow, "edit allowed")
	d = check_tool(.Auto, "write", "", nil, nil)
	testing.expect(t, d == .Allow, "write allowed")
	d = check_tool(.Auto, "delete_file", "", nil, nil)
	testing.expect(t, d == .Allow, "delete allowed")
	d = check_tool(.Auto, "run_terminal_cmd", "rm staging", nil, nil)
	testing.expect(t, d == .Ask, "write bash asks")
	d = check_tool(.Auto, "use_tool", "", nil, nil)
	testing.expect(t, d == .Ask, "mcp asks")
	d = check_tool(.Auto, "read_file", "", nil, nil)
	testing.expect(t, d == .Allow, "read allowed")
	// deny still wins
	deny := []string{"Edit"}
	d = check_tool(.Auto, "write", "", nil, deny)
	testing.expect(t, d == .Deny, "deny Edit")
}

@(test)
test_permission_mode_string_round_trip :: proc(t: ^testing.T) {
	modes := []Permission_Mode{.Always_Approve, .Auto, .Read_Only, .Ask}
	for mode in modes {
		s := permission_mode_string(mode)
		got, ok := permission_mode_from_string(s)
		testing.expectf(t, ok, "parse %s", s)
		testing.expect(t, got == mode, "round-trip")
	}
	// aliases
	got, ok := permission_mode_from_string("yolo")
	testing.expect(t, ok && got == .Always_Approve, "yolo alias")
	got, ok = permission_mode_from_string("readonly")
	testing.expect(t, ok && got == .Read_Only, "readonly alias")
	got, ok = permission_mode_from_string("accept-edits")
	testing.expect(t, ok && got == .Auto, "accept-edits alias")
	got, ok = permission_mode_from_string("auto")
	testing.expect(t, ok && got == .Auto, "auto is Auto not yolo")
}

@(test)
test_rule_for_always_allow_bash_and_edit :: proc(t: ^testing.T) {
	r := rule_for_always_allow("search_replace", "", context.allocator)
	defer delete(r)
	testing.expect(t, r == "Edit")

	r2 := rule_for_always_allow("run_terminal_cmd", "ls -la /tmp", context.allocator)
	defer delete(r2)
	testing.expect(t, r2 == "Bash(ls *)")

	r3 := rule_for_always_allow("run_terminal_cmd", "git status --short", context.allocator)
	defer delete(r3)
	testing.expect(t, r3 == "Bash(git status *)")

	r4 := rule_for_always_allow("run_terminal_cmd", "cargo test --lib", context.allocator)
	defer delete(r4)
	// cargo test is safe two-word → scope 2
	testing.expect(t, r4 == "Bash(cargo test *)")

	r5 := rule_for_always_allow("use_tool", "", context.allocator)
	defer delete(r5)
	testing.expect(t, r5 == "")
}

@(test)
test_default_always_allow_scope :: proc(t: ^testing.T) {
	words := []string{"ls", "src/foo"}
	testing.expect(t, default_always_allow_scope(words) == 1)
	words2 := []string{"git", "status", "--short"}
	testing.expect(t, default_always_allow_scope(words2) == 2)
	words3 := []string{"kubectl", "get", "pods", "-o", "json"}
	testing.expect(t, default_always_allow_scope(words3) == 2)
	words4 := []string{"make", "build"}
	// not safe-listed → min(2, n) = 2
	testing.expect(t, default_always_allow_scope(words4) == 2)
}

@(test)
test_session_allow_grants_ask_mode :: proc(t: ^testing.T) {
	session_allow_clear()
	defer session_allow_clear()

	// Without grant → Ask (write-like shell; not soft-readonly)
	d := check_tool(.Ask, "run_terminal_cmd", "rm staging.txt", nil, nil)
	testing.expect(t, d == .Ask)

	session_allow_add("Bash(rm *)")
	allow := merge_allow_lists(nil, context.temp_allocator)
	d = check_tool(.Ask, "run_terminal_cmd", "rm staging.txt", allow, nil)
	testing.expect(t, d == .Allow, "session grant matches")
	d = check_tool(.Ask, "run_terminal_cmd", "touch other", allow, nil)
	testing.expect(t, d == .Ask, "other commands still ask")
}

@(test)
test_allow_rule_match_returns_allow :: proc(t: ^testing.T) {
	allow := []string{"Edit"}
	d := check_tool(.Ask, "search_replace", "", allow, nil)
	testing.expect(t, d == .Allow)
	testing.expect(t, match_rule("Bash(git status *)", "run_terminal_cmd", "git status -sb"))
	testing.expect(t, !match_rule("Bash(git status *)", "run_terminal_cmd", "git push"))
}

@(test)
test_session_deny_blocks_even_always_approve :: proc(t: ^testing.T) {
	session_deny_clear()
	defer session_deny_clear()

	d := check_tool(.Always_Approve, "run_terminal_cmd", "rm -rf /tmp/x", nil, nil)
	testing.expect(t, d == .Allow)

	session_deny_add("Bash(rm *)")
	deny := merge_deny_lists(nil, context.temp_allocator)
	d = check_tool(.Always_Approve, "run_terminal_cmd", "rm -rf /tmp/x", nil, deny)
	testing.expect(t, d == .Deny, "session deny wins over always-approve")
	d = check_tool(.Always_Approve, "run_terminal_cmd", "ls", nil, deny)
	testing.expect(t, d == .Allow, "other commands still allowed")
}
