#!/usr/bin/env bash
# Aether (Odin) product launcher — self-contained under aether/.
# Resolves the built binary next to this tree; does not require crates/ or Cargo.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(builtin cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
AETHER_DIR="$(builtin cd -P "$(dirname "$SOURCE")/.." && pwd)"

# S1: default output under aether/out/aether (override with AETHER_OUT / AETHER_ODIN_BIN)
BIN="${AETHER_ODIN_BIN:-${AETHER_OUT:-$AETHER_DIR/out/aether}}"

# Compat: monorepo historical path if new OUT not built yet
if [[ ! -x "$BIN" && -x "$AETHER_DIR/../target/aether" ]]; then
  BIN="$AETHER_DIR/../target/aether"
fi

if [[ ! -x "$BIN" ]]; then
  echo "aether: binary not found at $BIN" >&2
  echo "Build with:" >&2
  echo "  cd \"$AETHER_DIR\" && make build" >&2
  echo "  # or: make -C aether bootstrap-odin build" >&2
  exit 127
fi
exec "$BIN" "$@"
